# Environment variables for Telegram Bot
# Copy this to .env for local development

# REQUIRED: Your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_here

# REQUIRED for production: Your Render app URL (or other hosting platform)
TELEGRAM_WEBHOOK_BASE=https://your-app-name.onrender.com

# OPTIONAL: Port for webhook (Render sets this automatically)
PORT=8000

# OPTIONAL: Bot owner ID for admin commands
BOT_OWNER_ID=your_telegram_user_id

# OPTIONAL: Cookie management for age-restricted videos
# Path to cookies file
YTDLP_COOKIES_FILE=/path/to/cookies.txt

# OR raw cookie contents (base64 encoded for Render environment variables)
YTDLP_COOKIES_B64=base64_encoded_cookies_here

# OR raw cookie contents (plain text)
YTDLP_COOKIES=raw_cookie_contents_here

# OPTIONAL: Download cookies from URL
YTDLP_COOKIES_URL=https://example.com/cookies.txt
YTDLP_COOKIES_URL_TOKEN=bearer_token_if_needed

# OPTIONAL: Cookie expiry in days (0 = never expire)
YTDLP_COOKIE_TTL_DAYS=7